# Supabase (obrigatório para auth)
# Obtenha em: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key

# Opcional: chave de serviço para operações server-side com bypass de RLS
# SUPABASE_SERVICE_ROLE_KEY=

# Opcional: OpenRouter — insights de reunião e insight estratégico do projeto (server-side)
# OPENROUTER_API_KEY=

# Opcional: para rodar migrações pelo CLI sem login interativo (e em CI)
# Obtenha o token em: https://supabase.com/dashboard/account/tokens
# SUPABASE_ACCESS_TOKEN=
# Ref do projeto = parte da URL do projeto (https://<REF>.supabase.co)
# SUPABASE_PROJECT_REF=
